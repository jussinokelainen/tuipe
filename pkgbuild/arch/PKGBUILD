# Maintainer: Jussi Nokelainen <jussinoke@gmail.com>
pkgname='tuipe-git'
pkgver=r45.dc3b824
pkgrel=1
pkgdesc='TUI typing trainer'
arch=('x86_64')
url=""
license=('GPL-3.0-only')
depends=('glibc')
makedepends=('git' 'cargo')
source=("$pkgname::git+https://github.com/jussinokelainen/tuipe.git")
options=('!debug')
sha256sums=('SKIP')

pkgver() {
	cd "$pkgname"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "$pkgname"
	make build
}

package() {
	cd "$pkgname"
	make install DESTDIR="$pkgdir"
}
