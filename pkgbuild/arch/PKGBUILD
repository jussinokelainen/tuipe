# Maintainer: Jussi Nokelainen <jussinoke@gmail.com>
pkgname='tuipe-git'
pkgver=r18.ef01f1c
pkgrel=1
pkgdesc='TUI typing trainer'
arch=('x86_64')
url=""
license=('GPL-3.0-only')
depends=('glibc')
makedepends=('git' 'cargo')
source=("$pkgname::git+ssh://kyogre/home/jussi/git/tuipe")
options=('!debug')
sha256sums=('SKIP')

pkgver() {
	cd "$pkgname"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "$pkgname"
	make build
}

package() {
	cd "$pkgname"
	ls target
	install -Dm755 target/release/tuipe "$pkgdir"/usr/bin/tuipe

	local files=(languages/*)
	local file
	for file in "${files[@]}"; do
		install -Dm755 "$file" "$pkgdir"/usr/share/tuipe/"$file"
	done
}
